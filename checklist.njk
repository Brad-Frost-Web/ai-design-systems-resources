---
layout: base.njk
permalink: /checklist/
---
{%- macro statusVariant(s) -%}
{%- if s == "green" -%}success{%- elif s == "yellow" -%}warning{%- else -%}error{%- endif -%}
{%- endmacro -%}

<ed-main class="checklist" data-checklist>
	<ed-layout-container>
		<div class="ed-r-c-inspection__sheet ed-u-checklist-stack">

		{# ── Letterhead (robot + masthead, on the paper) ─────────────────── #}
		<header class="ed-r-c-inspection__letterhead">
			<svg class="ed-r-c-inspection__robot" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 96 96" fill="none" role="img" aria-label="AI &amp; design systems robot">
				<rect y="28.5459" width="96" height="67.4541" rx="2" fill="#110000"/>
				<rect x="28.4883" y="20.8721" width="39.0244" height="67.1564" rx="16" fill="#110000"/>
				<rect x="46.0488" y="6.06104" width="3.90244" height="15.5115" fill="#110000"/>
				<ellipse cx="48" cy="5.76781" rx="5.7561" ry="5.76781" fill="#110000"/>
				<ellipse cx="28.4878" cy="54.6479" rx="16.9756" ry="17.0102" fill="#F6F5DE"/>
				<ellipse cx="28.4875" cy="54.6478" rx="9.07317" ry="9.09164" fill="#BE6700"/>
				<ellipse cx="66.9268" cy="54.6479" rx="16.9756" ry="17.0102" fill="#F6F5DE"/>
				<ellipse cx="66.9272" cy="54.6478" rx="9.07317" ry="9.09164" fill="#BE6700"/>
				<rect x="29.8535" y="79.5762" width="36.3902" height="5.27902" rx="2.63951" fill="#F6F5DE"/>
			</svg>
			<div class="ed-r-c-inspection__masthead">
				<h1 class="ed-r-c-inspection__title">Design System Inspection</h1>
				<p class="ed-r-c-inspection__lede">Check and improve the quality of your design system so AI agents and humans alike can use it to build great, on-brand products&mdash;fast.</p>
			</div>
		</header>

		{# ── The inspection table (product art direction) ────────────────── #}
		<section class="ed-u-checklist-section" aria-label="Design system inspection">
			<div class="ed-r-c-inspection__scroll">
				<table class="ed-r-c-inspection">
					<thead>
						<tr>
							<th class="ed-r-c-inspection__h ed-r-c-inspection__h--quality" scope="col">Quality</th>
							<th class="ed-r-c-inspection__h ed-r-c-inspection__h--station" scope="col">Station</th>
							<th class="ed-r-c-inspection__h ed-r-c-inspection__h--desc" scope="col">Description</th>
							<th class="ed-r-c-inspection__h ed-r-c-inspection__h--check" scope="col">
								<span class="ed-r-c-inspection__check-title">Check</span>
								<span class="ed-r-c-inspection__check-legend" aria-hidden="true">
									<span>Needs work</span><span>Okay</span><span>Good</span>
								</span>
							</th>
						</tr>
					</thead>
					{% for q in checklist.qualities %}
					<tbody class="ed-r-c-inspection__group" style="--q-accent: {{ q.accent }};" id="quality-{{ q.id }}">
						{% for s in q.stations %}
						<tr class="ed-r-c-inspection__row" data-station-card="{{ s.id }}" data-quality="{{ q.id }}">
							{% if loop.first %}
							<th class="ed-r-c-inspection__quality" scope="rowgroup" rowspan="{{ q.stations.length }}">
								<span class="ed-r-c-inspection__quality-icon" aria-hidden="true">{{ q.icon }}</span>
								<span class="ed-r-c-inspection__quality-name">{{ q.name }}</span>
							</th>
							{% endif %}
							<td class="ed-r-c-inspection__station">
								<span class="ed-r-c-inspection__num" aria-hidden="true">{{ s.number }}</span>
								<span class="ed-r-c-inspection__station-name">{{ s.name }}</span>
							</td>
							<td class="ed-r-c-inspection__desc">
								<p class="ed-r-c-inspection__q">{{ s.question | safe }}</p>
								<details class="ed-r-c-inspection__detail" data-details>
									<summary>Pop open the hood</summary>
									<div class="ed-r-c-inspection__detail-body">
										<div class="ed-r-c-inspection__detail-grid">
											<ed-text-passage size="sm">
												<h4>What to look out for</h4>
												<ul>{% for w in s.warningLights %}<li>{{ w | safe }}</li>{% endfor %}</ul>
											</ed-text-passage>
											<ed-text-passage size="sm">
												<h4>How you can wield AI</h4>
												<p>{{ s.aiHelps | safe }}</p>
											</ed-text-passage>
										</div>
										<ed-textarea-field
											fieldId="notes-{{ s.id }}"
											name="notes-{{ s.id }}"
											label="Your notes"
											rows="2"
											placeholder="What did you find? What's the plan?"
											data-notes="{{ s.id }}"
										></ed-textarea-field>
									</div>
								</details>
							</td>
							<td class="ed-r-c-inspection__check">
								<ed-r-status-rating station="{{ s.id }}" label="{{ s.name }} health" data-rating></ed-r-status-rating>
							</td>
						</tr>
						{% endfor %}
					</tbody>
					{% endfor %}
				</table>
			</div>
		</section>

		{# ── Scoreboard (Lighthouse-style quality gauges) ─────────────────── #}
		<section class="ed-u-checklist-scoreboard" data-dashboard hidden aria-label="Inspection score">
			<div class="ed-u-checklist-gauges">
				<ed-r-score-gauge data-overall size="lg" label="Overall"></ed-r-score-gauge>
				{% for q in checklist.qualities %}
				<ed-r-score-gauge data-quality="{{ q.id }}" size="sm" label="{{ q.name }}"></ed-r-score-gauge>
				{% endfor %}
			</div>
			<div class="ed-u-checklist-tallies">
				<ed-badge variant="error"><span data-count="red">0</span> broken</ed-badge>
				<ed-badge variant="warning"><span data-count="yellow">0</span> watch</ed-badge>
				<ed-badge variant="success"><span data-count="green">0</span> healthy</ed-badge>
				<ed-badge><span data-count="unset">10</span> unrated</ed-badge>
			</div>
			<p class="ed-u-checklist-scoreboard__note"><strong><span data-rated-count>0</span> of 10 stations rated.</strong> Scores weight each station green&nbsp;100 · yellow&nbsp;50 · red&nbsp;0. Fix reds first, then schedule yellows.</p>
			<ed-toolbar behavior="responsive">
				<ed-button slot="left" variant="bare" size="sm" data-action="expand" text="Expand all"></ed-button>
				<ed-button slot="left" variant="bare" size="sm" data-action="collapse" text="Collapse all"></ed-button>
				<ed-button slot="right" variant="bare" size="sm" data-action="print" text="Print"></ed-button>
				<ed-button slot="right" variant="danger" size="sm" data-action="reset" text="Reset"></ed-button>
			</ed-toolbar>
		</section>

		{# ── Worked example ──────────────────────────────────────────────── #}
		<ed-alert variant="success" tagName="h2" heading="A worked example">
			<ed-text-passage size="sm"><p>{{ checklist.results.example | safe }}</p></ed-text-passage>
		</ed-alert>

		{# ── Maintenance ─────────────────────────────────────────────────── #}
		<section class="ed-u-checklist-section" aria-labelledby="maintenance-heading">
			<ed-heading tagName="h2" id="maintenance-heading">{{ checklist.maintenance.heading }}</ed-heading>
			<ed-text-passage>
				<p>{{ checklist.maintenance.intro }}</p>
				<ul>
					{% for c in checklist.maintenance.cadences %}
					<li><strong>{{ c.lead }}</strong> {{ c.body | safe }}</li>
					{% endfor %}
				</ul>
			</ed-text-passage>
			<ed-alert variant="info" tagName="h3" heading="Keep the light off">
				<ed-text-passage size="sm"><p>{{ checklist.maintenance.outro }}</p></ed-text-passage>
			</ed-alert>
		</section>

		{# ── Appendix crosswalk ──────────────────────────────────────────── #}
		<section class="ed-u-checklist-section" aria-labelledby="crosswalk-heading">
			<details class="ed-u-checklist-details">
				<summary><ed-heading tagName="h2" variant="headline-sm" id="crosswalk-heading">{{ checklist.crosswalk.heading }}</ed-heading></summary>
				<div class="ed-u-checklist-details__body">
					<ed-text-passage size="sm"><p>{{ checklist.crosswalk.intro }}</p></ed-text-passage>
					<ed-table fullWidth>
						<ed-table-header>
							<ed-table-row>
								<ed-table-header-cell>Inspection station</ed-table-header-cell>
								<ed-table-header-cell>Scorecard criteria</ed-table-header-cell>
							</ed-table-row>
						</ed-table-header>
						<ed-table-body>
							{% for row in checklist.crosswalk.rows %}
							<ed-table-row>
								<ed-table-cell>{{ row.station }}</ed-table-cell>
								<ed-table-cell>{{ row.criteria }}</ed-table-cell>
							</ed-table-row>
							{% endfor %}
						</ed-table-body>
					</ed-table>
				</div>
			</details>
		</section>

		<ed-text-passage size="xs">
			<p>Source of truth: <a href="{{ checklist.meta.sourceUrl }}">DS inspection checklist</a> &middot; Chapter 3 of the <a href="https://aianddesign.systems">AI &amp; Design Systems course</a>. Warning signs cross-checked against <a href="https://southleft.com">Southleft&rsquo;s</a> AI-Ready Design System Scorecard.</p>
		</ed-text-passage>
		</div>
	</ed-layout-container>
</ed-main>
