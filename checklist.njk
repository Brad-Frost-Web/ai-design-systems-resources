---
layout: base.njk
permalink: /checklist/
---
{%- macro statusVariant(s) -%}
{%- if s == "green" -%}success{%- elif s == "yellow" -%}warning{%- else -%}error{%- endif -%}
{%- endmacro -%}

<ed-main class="checklist" data-checklist>
	<ed-r-course-hero compact>
		<ed-heading tagName="h1">AI-ready design system inspection</ed-heading>
		<p slot="eyebrow">Check and improve the quality of your design system so AI agents and humans alike can use it to build great, on-brand products&mdash;fast.</p>
	</ed-r-course-hero>

	<ed-layout-container class="ed-u-checklist-stack">

		{# ── The five qualities overview ─────────────────────────────────── #}
		<section class="ed-u-checklist-section" aria-labelledby="qualities-heading">
			<ed-heading tagName="h2" id="qualities-heading">The five qualities of an AI-ready design system</ed-heading>
			<ed-text-passage><p>{{ checklist.overviewIntro | safe }}</p></ed-text-passage>
			<ed-grid variant="3up">
				{% for q in checklist.qualities %}
				<ed-grid-item>
					<ed-card>
						<ed-heading tagName="h3" variant="title"><a href="#quality-{{ q.id }}">{{ q.name }}</a></ed-heading>
						<ed-text-passage size="sm"><p>{{ q.question }}</p></ed-text-passage>
					</ed-card>
				</ed-grid-item>
				{% endfor %}
			</ed-grid>
		</section>

		{# ── Key (how to use) ────────────────────────────────────────────── #}
		<details class="ed-u-checklist-details ed-u-checklist-key">
			<summary>{{ checklist.howToUse.heading }}</summary>
			<div class="ed-u-checklist-details__body">
				<ed-text-passage size="sm"><p>{{ checklist.howToUse.body | safe }}</p></ed-text-passage>
				<ul class="ed-u-checklist-legend">
					{% for opt in checklist.howToUse.legend %}
					<li><ed-badge variant="{{ statusVariant(opt.status) }}" appearance="solid" text="{{ opt.label }}"></ed-badge> {{ opt.desc }}</li>
					{% endfor %}
				</ul>
			</div>
		</details>

		{# ── Scoreboard (Lighthouse-style quality gauges) ─────────────────── #}
		<section class="ed-u-checklist-scoreboard" data-dashboard hidden aria-label="Inspection score">
			<div class="ed-u-checklist-gauges">
				<ed-r-score-gauge data-overall size="lg" label="Overall"></ed-r-score-gauge>
				{% for q in checklist.qualities %}
				<ed-r-score-gauge data-quality="{{ q.id }}" size="sm" label="{{ q.name }}"></ed-r-score-gauge>
				{% endfor %}
			</div>
			<div class="ed-u-checklist-tallies">
				<ed-badge variant="error"><span data-count="red">0</span> broken</ed-badge>
				<ed-badge variant="warning"><span data-count="yellow">0</span> watch</ed-badge>
				<ed-badge variant="success"><span data-count="green">0</span> healthy</ed-badge>
				<ed-badge><span data-count="unset">10</span> unrated</ed-badge>
			</div>
			<p class="ed-u-checklist-scoreboard__note"><strong><span data-rated-count>0</span> of 10 stations rated.</strong> Scores weight each station green&nbsp;100 · yellow&nbsp;50 · red&nbsp;0. Fix reds first, then schedule yellows.</p>
			<ed-toolbar behavior="responsive">
				<ed-button slot="left" variant="bare" size="sm" data-action="expand" text="Expand all"></ed-button>
				<ed-button slot="left" variant="bare" size="sm" data-action="collapse" text="Collapse all"></ed-button>
				<ed-button slot="right" variant="bare" size="sm" data-action="print" text="Print"></ed-button>
				<ed-button slot="right" variant="danger" size="sm" data-action="reset" text="Reset"></ed-button>
			</ed-toolbar>
		</section>

		{# ── The stations ────────────────────────────────────────────────── #}
		{% for q in checklist.qualities %}
		<section class="ed-u-checklist-section" id="quality-{{ q.id }}" aria-labelledby="quality-{{ q.id }}-heading">
			<ed-heading tagName="h2" id="quality-{{ q.id }}-heading">{{ q.name }}</ed-heading>
			<ed-text-passage>
				<p><strong>{{ q.question }}</strong></p>
				<p>{{ q.intro | safe }}</p>
			</ed-text-passage>

			{% for s in q.stations %}
			<ed-card class="ed-u-checklist-station" data-station-card="{{ s.id }}" data-quality="{{ q.id }}">
				<div class="ed-u-checklist-station__head">
					<div class="ed-u-checklist-station__titles">
						<ed-badge text="Station {{ s.number }}"></ed-badge>
						<ed-heading tagName="h3" variant="headline-sm">{{ s.name }}</ed-heading>
					</div>
					<ed-r-status-rating station="{{ s.id }}" label="{{ s.name }} health" data-rating></ed-r-status-rating>
				</div>

				<ed-text-passage>
					<p><strong>{{ s.question | safe }}</strong> <em>{{ s.examples | safe }}</em></p>
				</ed-text-passage>

				<details class="ed-u-checklist-details" data-details>
					<summary>Warning signs &amp; how AI helps</summary>
					<div class="ed-u-checklist-details__body">
						<ed-text-passage size="sm">
							<h4>Warning signs</h4>
							<ul>{% for w in s.warningLights %}<li>{{ w | safe }}</li>{% endfor %}</ul>
							<h4>How AI helps</h4>
							<p>{{ s.aiHelps | safe }}</p>
						</ed-text-passage>
						<ed-textarea-field
							fieldId="notes-{{ s.id }}"
							name="notes-{{ s.id }}"
							label="Your notes"
							rows="2"
							placeholder="What did you find? What's the plan?"
							data-notes="{{ s.id }}"
						></ed-textarea-field>
					</div>
				</details>
			</ed-card>
			{% endfor %}
		</section>
		{% endfor %}

		{# ── Results ─────────────────────────────────────────────────────── #}
		<section class="ed-u-checklist-section" aria-labelledby="results-heading">
			<ed-heading tagName="h2" id="results-heading">Your inspection results</ed-heading>
			<ed-table fullWidth>
				<ed-table-header>
					<ed-table-row>
						<ed-table-header-cell>Quality / Station</ed-table-header-cell>
						<ed-table-header-cell>Health</ed-table-header-cell>
					</ed-table-row>
				</ed-table-header>
				<ed-table-body>
					{% for q in checklist.qualities %}
					{% for s in q.stations %}
					<ed-table-row>
						<ed-table-cell><a href="#quality-{{ q.id }}">{{ q.name }} &middot; Station {{ s.number }}: {{ s.name }}</a></ed-table-cell>
						<ed-table-cell><ed-badge data-result="{{ s.id }}" text="Not yet rated"></ed-badge></ed-table-cell>
					</ed-table-row>
					{% endfor %}
					{% endfor %}
				</ed-table-body>
			</ed-table>
			<ed-text-passage><p><strong>Greens: <span data-score>0</span> / 10.</strong> {{ checklist.results.scoreNote }}</p></ed-text-passage>
			<ed-alert variant="success" tagName="h3" heading="Worked example">
				<ed-text-passage size="sm"><p>{{ checklist.results.example | safe }}</p></ed-text-passage>
			</ed-alert>
		</section>

		{# ── Maintenance ─────────────────────────────────────────────────── #}
		<section class="ed-u-checklist-section" aria-labelledby="maintenance-heading">
			<ed-heading tagName="h2" id="maintenance-heading">{{ checklist.maintenance.heading }}</ed-heading>
			<ed-text-passage>
				<p>{{ checklist.maintenance.intro }}</p>
				<ul>
					{% for c in checklist.maintenance.cadences %}
					<li><strong>{{ c.lead }}</strong> {{ c.body | safe }}</li>
					{% endfor %}
				</ul>
			</ed-text-passage>
			<ed-alert variant="info" tagName="h3" heading="Keep the light off">
				<ed-text-passage size="sm"><p>{{ checklist.maintenance.outro }}</p></ed-text-passage>
			</ed-alert>
		</section>

		{# ── Appendix crosswalk ──────────────────────────────────────────── #}
		<section class="ed-u-checklist-section" aria-labelledby="crosswalk-heading">
			<details class="ed-u-checklist-details">
				<summary><ed-heading tagName="h2" variant="headline-sm" id="crosswalk-heading">{{ checklist.crosswalk.heading }}</ed-heading></summary>
				<div class="ed-u-checklist-details__body">
					<ed-text-passage size="sm"><p>{{ checklist.crosswalk.intro }}</p></ed-text-passage>
					<ed-table fullWidth>
						<ed-table-header>
							<ed-table-row>
								<ed-table-header-cell>Inspection station</ed-table-header-cell>
								<ed-table-header-cell>Scorecard criteria</ed-table-header-cell>
							</ed-table-row>
						</ed-table-header>
						<ed-table-body>
							{% for row in checklist.crosswalk.rows %}
							<ed-table-row>
								<ed-table-cell>{{ row.station }}</ed-table-cell>
								<ed-table-cell>{{ row.criteria }}</ed-table-cell>
							</ed-table-row>
							{% endfor %}
						</ed-table-body>
					</ed-table>
				</div>
			</details>
		</section>

		<ed-text-passage size="xs">
			<p>Source of truth: <a href="{{ checklist.meta.sourceUrl }}">DS inspection checklist</a> &middot; Chapter 3 of the <a href="https://aianddesign.systems">AI &amp; Design Systems course</a>.</p>
		</ed-text-passage>
	</ed-layout-container>
</ed-main>
