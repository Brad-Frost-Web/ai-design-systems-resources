{# Recently Shared in Slack section #}
{% set slackResources = [] %}
{% for resource in resources %}
  {% if resource.source == "slack" %}
    {% set slackResources = (slackResources.push(resource), slackResources) %}
  {% endif %}
{% endfor %}

{% if slackResources.length %}
<section class="resource-recent-slack">
  <ed-heading tagName="h2" variant="headline-default">Recently Shared in Slack</ed-heading>
  <ed-grid variant="2up">
    {% for resource in slackResources.slice(0, 10) %}
    <ed-grid-item>
      {% include "resource-card.njk" %}
    </ed-grid-item>
    {% endfor %}
  </ed-grid>
</section>
{% endif %}

{# Collect all unique tags across all resources #}
{% set allTags = [] %}
{% for resource in resources %}
  {% for tag in resource.tags %}
    {% set tagExists = false %}
    {% for existingTag in allTags %}
      {% if existingTag.name == tag.name %}
        {% set tagExists = true %}
      {% endif %}
    {% endfor %}
    {% if not tagExists %}
      {% set allTags = (allTags.push({ name: tag.name, color: tag.color }), allTags) %}
    {% endif %}
  {% endfor %}
{% endfor %}

{# Sort tags alphabetically by name #}
{% set sortedTags = allTags | sort(attribute='name') %}

<div class="resource-category-list">
    <ed-grid variant="2up">
  {% for tag in sortedTags %}
  <ed-grid-item>
    <section class="resource-category">
      <ed-heading tagName="h2" variant="headline-default" class="resource-category__heading">
        {{ tag.name }}
      </ed-heading>
      <ul class="resource-category__links">
        {% for resource in resources %}
          {% set hasTag = false %}
          {% for resourceTag in resource.tags %}
            {% if resourceTag.name == tag.name %}
              {% set hasTag = true %}
            {% endif %}
          {% endfor %}
          {% if hasTag %}
          <li>
            <a href="{{ resource.href }}" target="_blank" rel="noopener noreferrer">{{ resource.title }}</a>
          </li>
          {% endif %}
        {% endfor %}
      </ul>
    </section>
    </ed-grid-item>
  {% endfor %}
  </ed-grid>
</div>
